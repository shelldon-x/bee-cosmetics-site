    { "source": "/bee-yourself", "destination": "/#bee-yourself", "permanent": false },
    { "source": "/let-it-bee", "destination": "/#let-it-bee", "permanent": false },
    { "source": "/bee-proud", "destination": "/#bee-proud", "permanent": false },
    { "source": "/be-my-bee", "destination": "/#be-my-bee", "permanent": false },
    { "source": "/beelieve-in-acid", "destination": "/#beelieve-in-acid", "permanent": false },

